{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Postiz Setup Wizard",
  "version": "0.5.2",
  "identifier": "com.postiz.setup-wizard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Postiz Setup Wizard",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src http://localhost:* https://*; img-src 'self' data: https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNkI2OUI4NTJDRTUxMzkKUldRNVVjNVN1R2xyd1QrMmozVm1TUzlXZUhGU0ZraHFyRnBhY3dTTFA1eERtbE90eGYzT3NNWlYK",
      "endpoints": [
        "https://github.com/SamWylde/postiz-setup-wizard/releases/latest/download/latest.json"
      ]
    }
  }
}
